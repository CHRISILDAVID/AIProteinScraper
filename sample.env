# Bright Data (optional)
SBR_WEBDRIVER=""

# Azure Proxy (optional)
AZURE_PROXY_URL=""
PROXY_USERNAME=""
PROXY_PASSWORD=""

# ProxyScrape (recommended for higher request limits)
# Option A: comma/semicolon/newline separated full proxy URLs
# Example: http://user:pass@host1:port1,http://user:pass@host2:port2
PROXYSCRAPE_PROXY_LIST=""

# Option B: single proxy endpoint (used if PROXYSCRAPE_PROXY_LIST is empty)
PROXYSCRAPE_SCHEME="http"
PROXYSCRAPE_HOST=""
PROXYSCRAPE_PORT=""
PROXYSCRAPE_USERNAME=""
PROXYSCRAPE_PASSWORD=""

# Number of retries with different proxies before failing
PROXYSCRAPE_RETRIES="6"

# Inference providers
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OLLAMA_MODEL="gemma2:2b"
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Embedding models (used for RAG retrieval)
EMBEDDING_MODEL_OPENAI="text-embedding-3-small"
EMBEDDING_MODEL_GEMINI="models/gemini-embedding-001"
EMBEDDING_MODEL_OLLAMA="nomic-embed-text"
